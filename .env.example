# NaviCraft Configuration
# Copy this to .env and fill in your values

# --- Host Settings (used by docker-compose) ---
MUSIC_PATH=/mnt/user/media/music
APPDATA_PATH=/mnt/user/appdata/navicraft
NAVICRAFT_PORT=8085

# --- Music Directory (path inside container, don't change unless you know why) ---
MUSIC_DIR=/music

# --- Navidrome Connection ---
NAVIDROME_URL=http://navidrome:4533
NAVIDROME_USER=admin
NAVIDROME_PASSWORD=your_password_here

# --- AI Provider: "claude" or "gemini" ---
AI_PROVIDER=claude

# Claude (Anthropic)
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Gemini (Google) — only needed if AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Spotify (optional — best popularity data) ---
# Create a free app at https://developer.spotify.com/dashboard
# No Spotify subscription needed — free account works
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Last.fm (optional — improves popularity scoring) ---
# Get a free API key at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# --- Scanner ---
SCAN_INTERVAL_HOURS=6
SCAN_EXTENSIONS=.mp3,.flac,.ogg,.opus,.m4a,.wma,.aac,.wav,.aiff,.ape,.wv,.mpc

# --- AI Tuning ---
MAX_CANDIDATES=500

# --- Database ---
DB_PATH=/data/navicraft.db
